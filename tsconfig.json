{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["mocha", "node", "vscode"]
  },
  "include": [
    "client/src/**/*.ts",
    "server/src/**/*.ts",
    "server/generated/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
